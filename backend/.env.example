# Copy to .env (Komodo: set these as stack environment variables). Never commit real values.

ANTHROPIC_API_KEY=sk-ant-...
# claude-opus-4-8 (best) | claude-sonnet-5 (cheaper, still strong) | claude-haiku-4-5 (cheapest)
ANTHROPIC_MODEL=claude-opus-4-8

POSTGRES_PASSWORD=change-me-strong-password

# Shared secret the iPhone app sends as "Authorization: Bearer <API_KEY>".
# Leave blank only if the API is on a trusted LAN / behind auth already.
API_KEY=pick-a-long-random-string

DAILY_CALORIE_GOAL=2000
